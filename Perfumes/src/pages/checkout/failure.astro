---
import Layout from '../../layouts/Layout.astro';

const orderId = Astro.url.searchParams.get('orderId');
---

<Layout title="Pago Fallido | Lé Désir" description="Tu pago no pudo ser procesado correctamente en Lé Désir.">
  <main class="bg-brand-light min-h-screen pt-40 pb-32 flex items-center">
    <div class="container mx-auto px-4 md:px-8 max-w-md">
      <div class="bg-brand-white border border-brand-dark/5 p-8 md:p-12 shadow-md rounded-xs text-center space-y-6 animate-fade-in">
        <div class="w-16 h-16 bg-red-50 border border-red-200 text-red-600 rounded-full flex items-center justify-center mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
        </div>

        <div class="space-y-2">
          <span class="text-xs uppercase tracking-widest text-red-500 font-semibold">El pago no pudo procesarse</span>
          <h1 class="font-serif text-2xl md:text-3xl text-brand-dark lowercase">pago fallido o cancelado</h1>
          <p class="text-sm text-brand-dark/55 font-light leading-relaxed">
            No se pudo completar el cobro de tu orden {orderId && ` #${orderId}`}. Esto puede deberse a fondos insuficientes, datos incorrectos de la tarjeta, o cancelación manual del flujo de pago.
          </p>
        </div>

        <div class="flex flex-col gap-2 pt-4">
          <a
            href="/shop"
            class="bg-brand-dark text-brand-white py-4 uppercase tracking-widest text-xs font-semibold hover:bg-brand-gold transition-colors shadow-xs"
          >
            Volver a la tienda
          </a>
          <a
            href="/"
            class="border border-brand-dark/10 hover:border-brand-dark/30 text-brand-dark/65 py-4 uppercase tracking-widest text-xs font-semibold bg-transparent transition-colors"
          >
            Página de inicio
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
