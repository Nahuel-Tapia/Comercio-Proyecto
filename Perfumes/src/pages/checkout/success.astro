---
import Layout from '../../layouts/Layout.astro';
import db from '../../lib/db';
import { SITE } from '../../data/site';

const orderId = Astro.url.searchParams.get('orderId');
const simulated = Astro.url.searchParams.get('simulated') === 'true';

// Buscar la orden en la base de datos
const order = orderId ? db.prepare('SELECT * FROM orders WHERE id = ?').get(orderId) as any : null;

// Si la simulación está activa y el pago estaba pendiente, lo aprobamos automáticamente para facilitar pruebas
if (order && order.payment_status === 'Pendiente' && simulated) {
  db.prepare(`
    UPDATE orders 
    SET status = 'Completado', payment_status = 'Aprobado', payment_id = ? 
    WHERE id = ?
  `).run(`SIM-PAY-${orderId}`, orderId);
  
  // Actualizar objeto en memoria para renderizado
  order.status = 'Completado';
  order.payment_status = 'Aprobado';
  order.payment_id = `SIM-PAY-${orderId}`;
}

const items = order ? JSON.parse(order.items_json) : [];

// Formatear mensaje para WhatsApp
const whatsappMessage = order
  ? `Hola! Acabo de completar el pago de mi pedido #${order.id} por $${order.total.toLocaleString('es-AR')} en la web. ¿Cuándo se realizaría el despacho/retiro?`
  : 'Hola, tengo una consulta sobre mi pedido.';
const whatsappUrl = `https://wa.me/${SITE.whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<Layout title="Compra Exitosa | Lé Désir" description="Tu pago ha sido procesado correctamente en Lé Désir.">
  <main class="bg-brand-light min-h-screen pt-40 pb-32 flex items-center">
    <div class="container mx-auto px-4 md:px-8 max-w-2xl">
      {order ? (
        <div class="bg-brand-white border border-brand-dark/5 p-8 md:p-12 shadow-md rounded-xs text-center space-y-8 animate-fade-in">
          <div class="w-16 h-16 bg-green-50 border border-green-200 text-green-600 rounded-full flex items-center justify-center mx-auto">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>

          <div class="space-y-3">
            <span class="text-xs uppercase tracking-widest text-brand-gold font-semibold">¡Pago Aprobado con Éxito!</span>
            <h1 class="font-serif text-3xl md:text-4xl text-brand-dark lowercase">gracias por tu compra</h1>
            <p class="text-sm text-brand-dark/60 font-light max-w-md mx-auto leading-relaxed">
              Hemos registrado tu pedido. Tu pago ha sido validado y estamos preparando tu paquete de fragancias premium.
            </p>
          </div>

          <div class="border-y border-brand-dark/5 py-6 text-left space-y-4 max-w-md mx-auto">
            <div class="flex justify-between text-xs uppercase tracking-wider text-brand-dark/45 font-medium">
              <span>Pedido ID:</span>
              <span class="text-brand-dark font-bold">#{order.id}</span>
            </div>
            <div class="flex justify-between text-xs uppercase tracking-wider text-brand-dark/45 font-medium">
              <span>Método de pago:</span>
              <span class="text-brand-dark">Mercado Pago {simulated && '(Simulado)'}</span>
            </div>
            {order.payment_id && (
              <div class="flex justify-between text-xs uppercase tracking-wider text-brand-dark/45 font-medium">
                <span>Transacción ID:</span>
                <span class="text-brand-dark font-mono text-[11px]">{order.payment_id}</span>
              </div>
            )}
            <div class="flex justify-between text-xs uppercase tracking-wider text-brand-dark/45 font-medium">
              <span>Estado del pedido:</span>
              <span class="text-green-600 font-semibold">{order.status}</span>
            </div>
            <div class="flex justify-between text-sm uppercase tracking-wider border-t border-brand-dark/5 pt-4 font-semibold">
              <span class="text-brand-dark">Total pagado:</span>
              <span class="text-brand-dark">${order.total.toLocaleString('es-AR')}</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 justify-center pt-4">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-brand-dark text-brand-white px-8 py-4 uppercase tracking-widest text-xs font-semibold hover:bg-brand-gold transition-colors shadow-xs inline-flex items-center justify-center gap-2"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-whatsapp" viewBox="0 0 16 16">
                <path d="M13.601 2.326A7.85 7.85 0 0 0 10.64 0H10.64a8.04 8.04 0 0 0-7.29 4.39A8 8 0 0 0 2.23 9.49L.1 16l6.63-1.74a7.8 7.8 0 0 0 3.79.97h.007a8 8 0 0 0 6.64-3.79A7.8 7.8 0 0 0 13.6 2.326zM10.64 14.63h-.008a6.7 6.7 0 0 1-3.41-.93l-.24-.14-3.95 1.04 1.06-3.89-.16-.25a6.7 6.7 0 0 1-1.04-3.64C2.93 3.66 6.39.2 10.64.2C14.89.2 18 3.66 18 7.89a8 8 0 0 1-7.36 6.74M16.63 7.89c0-3.52-2.88-6.39-6.42-6.39C6.67 1.5 4 4.38 4 7.9c0 1.25.32 2.47.94 3.51l-.64 2.35 2.41-.63a6.4 6.4 0 0 0 3.11.8h.006c3.55 0 6.43-2.87 6.43-6.39"/>
              </svg>
              Coordinar por WhatsApp
            </a>
            <a
              href="/shop"
              class="border border-brand-dark/15 text-brand-dark hover:border-brand-dark px-8 py-4 uppercase tracking-widest text-xs font-semibold bg-transparent transition-colors flex items-center justify-center"
            >
              Volver al catálogo
            </a>
          </div>
        </div>
      ) : (
        <div class="bg-brand-white border border-brand-dark/5 p-8 md:p-12 shadow-md rounded-xs text-center space-y-6 animate-fade-in">
          <div class="w-16 h-16 bg-red-50 border border-red-200 text-red-600 rounded-full flex items-center justify-center mx-auto">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
            </svg>
          </div>
          <div class="space-y-2">
            <h1 class="font-serif text-2xl text-brand-dark lowercase">pedido no encontrado</h1>
            <p class="text-sm text-brand-dark/50 font-light max-w-sm mx-auto leading-relaxed">
              No hemos podido encontrar los detalles del pedido solicitado. Si crees que esto es un error, por favor contáctanos.
            </p>
          </div>
          <a
            href="/shop"
            class="bg-brand-dark text-brand-white px-8 py-4 uppercase tracking-widest text-xs font-semibold hover:bg-brand-gold transition-colors shadow-xs inline-block"
          >
            Volver a la tienda
          </a>
        </div>
      )}
    </div>
  </main>
</Layout>
