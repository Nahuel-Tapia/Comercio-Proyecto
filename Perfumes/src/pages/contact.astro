---
import Layout from '../layouts/Layout.astro';
import { SITE, whatsappLink } from '../data/site';

const whatsappHref = whatsappLink('Hola, quiero asesoramiento para elegir una fragancia.');
---

<Layout title="Contacto | Lé Désir Fragancias" description="Contactá a Lé Désir para asesoramiento olfativo, pedidos, envíos y consultas sobre fragancias.">
  <div class="bg-brand-light min-h-screen pt-40 pb-32">
    <div class="container mx-auto px-4 md:px-8 max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">
        <div class="md:col-span-5 space-y-5">
          <span class="text-xs uppercase tracking-[0.3em] text-brand-gold font-semibold block">contacto</span>
          <h1 class="font-serif text-4xl md:text-5xl text-brand-dark font-light lowercase">asesoría personal</h1>
          <p class="text-sm sm:text-base text-brand-dark/60 font-light leading-relaxed">
            Si estás entre varias fragancias, buscás un regalo o querés coordinar un pedido, escribinos y te ayudamos a elegir.
          </p>
          <div class="pt-5 flex flex-col sm:flex-row md:flex-col gap-4">
            <a
              href={whatsappHref}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-brand-dark text-brand-white px-8 py-4 text-xs uppercase tracking-widest font-semibold hover:bg-brand-gold transition-colors text-center"
            >
              Escribir por WhatsApp
            </a>
            <a
              href={SITE.instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="border border-brand-dark/15 text-brand-dark px-8 py-4 text-xs uppercase tracking-widest font-semibold hover:border-brand-dark transition-colors text-center"
            >
              Ver Instagram
            </a>
          </div>
        </div>

        <div class="md:col-span-7 bg-[#F3F0E9] border border-brand-dark/5 p-7 md:p-10">
          <h2 class="font-serif text-2xl text-brand-dark font-light lowercase mb-8">consulta rápida</h2>
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-xs uppercase tracking-widest text-brand-dark/55 mb-2 font-medium">Nombre</label>
                <input name="nombre" required class="w-full bg-transparent border-b border-brand-dark/15 focus:border-brand-dark px-1 py-2 text-sm focus:outline-none" />
              </div>
              <div>
                <label class="block text-xs uppercase tracking-widest text-brand-dark/55 mb-2 font-medium">Teléfono</label>
                <input name="telefono" class="w-full bg-transparent border-b border-brand-dark/15 focus:border-brand-dark px-1 py-2 text-sm focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="block text-xs uppercase tracking-widest text-brand-dark/55 mb-2 font-medium">Qué estás buscando</label>
              <select name="motivo" class="w-full bg-transparent border-b border-brand-dark/15 focus:border-brand-dark px-1 py-2 text-sm focus:outline-none">
                <option>Asesoramiento para mí</option>
                <option>Regalo</option>
                <option>Pedido o envío</option>
                <option>Otra consulta</option>
              </select>
            </div>
            <div>
              <label class="block text-xs uppercase tracking-widest text-brand-dark/55 mb-2 font-medium">Mensaje</label>
              <textarea name="mensaje" required rows="5" class="w-full bg-transparent border-b border-brand-dark/15 focus:border-brand-dark px-1 py-2 text-sm focus:outline-none resize-none"></textarea>
            </div>
            <button type="submit" class="bg-brand-dark text-brand-white px-8 py-4 text-xs uppercase tracking-widest font-semibold hover:bg-brand-gold transition-colors">
              Enviar consulta
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = {
        name: formData.get('nombre'),
        phone: formData.get('telefono'),
        reason: formData.get('motivo'),
        message: formData.get('mensaje'),
      };

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();
        if (res.ok) {
          window.dispatchEvent(
            new CustomEvent('toast', {
              detail: { type: 'success', message: result.message || 'Consulta enviada con éxito' },
            })
          );
          form.reset();
        } else {
          window.dispatchEvent(
            new CustomEvent('toast', {
              detail: { type: 'error', message: result.error || 'Error al enviar consulta' },
            })
          );
        }
      } catch (err) {
        window.dispatchEvent(
          new CustomEvent('toast', {
            detail: { type: 'error', message: 'Error de red al enviar la consulta' },
          })
        );
      }
    });
  </script>
</Layout>
